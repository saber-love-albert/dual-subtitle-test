<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SubFloat AI - Netflix 雙語字幕懸浮工具</title>
    <!-- Tailwind CSS for modern premium UI -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&family=Poppins:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', 'Noto Sans TC', sans-serif;
        }
    </style>
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-screen flex flex-col justify-between">

    <!-- Header -->
    <header class="border-b border-zinc-800 bg-zinc-900/50 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-md mx-auto px-4 py-3 flex justify-between items-center">
            <div class="flex items-center space-x-2">
                <span class="w-3 h-3 bg-red-600 rounded-full animate-pulse"></span>
                <h1 class="text-lg font-bold tracking-wider text-white">SUBFLOAT AI</h1>
            </div>
            <span class="text-xs bg-zinc-800 text-zinc-400 px-2.5 py-1 rounded-full border border-zinc-700">v2.1 行動極客版</span>
        </div>
    </header>

    <!-- Main Container -->
    <main class="flex-grow max-w-md w-full mx-auto px-4 py-6 space-y-6">
        
        <!-- Hero Introduction -->
        <div class="bg-gradient-to-br from-zinc-900 to-zinc-950 p-5 rounded-2xl border border-zinc-800 space-y-2 shadow-xl">
            <h2 class="text-base font-semibold text-red-500">🏆 100% 繞過 DRM 安全限制</h2>
            <p class="text-xs text-zinc-400 leading-relaxed">
                本工具利用 Android 系統的 <b>Picture-in-Picture (PiP)</b> 畫中畫技術，生成一個可自由拖曳、重疊在 Netflix App 最上方的雙語字幕浮動條。完全不需 Root、不需安裝 APK、絕不卡死黑畫面！
            </p>
        </div>

        <!-- Step 1: Subtitle Input -->
        <div class="bg-zinc-900 p-5 rounded-2xl border border-zinc-800/80 space-y-4 shadow-md">
            <div class="flex justify-between items-center">
                <h3 class="text-sm font-bold text-zinc-300 flex items-center">
                    <span class="bg-red-900/50 text-red-400 text-xs w-5 h-5 rounded-full flex items-center justify-center mr-2 font-mono">1</span>
                    匯入字幕資料源
                </h3>
                <button onclick="loadDemoSubtitles()" class="text-xs text-red-400 hover:text-red-300 font-medium transition">
                    載入測試示範字幕
                </button>
            </div>

            <!-- Single or Split File Choice -->
            <div class="grid grid-cols-2 gap-2 p-1 bg-zinc-950 rounded-lg border border-zinc-800/50">
                <button onclick="switchTab('single')" id="tab-single" class="text-xs py-2 rounded-md font-medium text-center transition bg-zinc-800 text-white">
                    中英混合/單一檔案
                </button>
                <button onclick="switchTab('dual')" id="tab-dual" class="text-xs py-2 rounded-md font-medium text-center transition text-zinc-400 hover:text-zinc-200">
                    獨立雙檔案合併
                </button>
            </div>

            <!-- Single Input Form -->
            <div id="panel-single" class="space-y-3">
                <div class="space-y-1">
                    <label class="block text-xs text-zinc-500">上傳 SRT/VTT 檔案</label>
                    <input type="file" id="file-single" accept=".srt,.vtt" onchange="handleSingleFile(event)" class="w-full text-xs bg-zinc-950 p-2.5 rounded-lg border border-zinc-800 text-zinc-300 file:mr-2 file:bg-zinc-800 file:border-0 file:text-xs file:px-2.5 file:py-1 file:rounded file:text-zinc-200 file:cursor-pointer">
                </div>
                <div class="relative">
                    <div class="absolute inset-0 flex items-center" aria-hidden="true">
                        <div class="w-full border-t border-zinc-800/60"></div>
                    </div>
                    <div class="relative flex justify-center text-xs">
                        <span class="bg-zinc-900 px-2 text-zinc-600">或直接貼上字幕文字</span>
                    </div>
                </div>
                <textarea id="text-single" placeholder="請在此貼上帶有時間軸的 SRT/VTT 字幕內容..." class="w-full h-24 bg-zinc-950 border border-zinc-800 rounded-xl p-3 text-xs font-mono text-zinc-400 focus:outline-none focus:border-red-600 focus:ring-1 focus:ring-red-600 transition"></textarea>
            </div>

            <!-- Dual Input Form -->
            <div id="panel-dual" class="space-y-3 hidden">
                <div class="space-y-3">
                    <div>
                        <label class="block text-xs text-zinc-400 mb-1">1. 上傳英文 (目標語言) SRT/VTT</label>
                        <input type="file" id="file-en" accept=".srt,.vtt" onchange="handleDualFile(event, 'en')" class="w-full text-xs bg-zinc-950 p-2.5 rounded-lg border border-zinc-800 text-zinc-300 file:mr-2 file:bg-zinc-800 file:border-0 file:text-xs file:px-2.5 file:py-1 file:rounded file:text-zinc-200">
                    </div>
                    <div>
                        <label class="block text-xs text-zinc-400 mb-1">2. 上傳中文 (母語翻譯) SRT/VTT</label>
                        <input type="file" id="file-zh" accept=".srt,.vtt" onchange="handleDualFile(event, 'zh')" class="w-full text-xs bg-zinc-950 p-2.5 rounded-lg border border-zinc-800 text-zinc-300 file:mr-2 file:bg-zinc-800 file:border-0 file:text-xs file:px-2.5 file:py-1 file:rounded file:text-zinc-200">
                    </div>
                </div>
            </div>

            <button onclick="parseSubtitles()" class="w-full bg-red-600/90 hover:bg-red-600 text-white font-semibold text-xs py-2.5 rounded-xl transition shadow-lg shadow-red-900/10 active:scale-[0.98]">
                分析並載入字幕
            </button>
        </div>

        <!-- Step 2: Styling and Customization -->
        <div class="bg-zinc-900 p-5 rounded-2xl border border-zinc-800/80 space-y-4 shadow-md">
            <h3 class="text-sm font-bold text-zinc-300 flex items-center">
                <span class="bg-red-900/50 text-red-400 text-xs w-5 h-5 rounded-full flex items-center justify-center mr-2 font-mono">2</span>
                懸浮視窗樣式調校
            </h3>
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                    <label class="text-xs text-zinc-500 block">英文 (主字幕) 顏色</label>
                    <select id="color-en" onchange="updateCanvas()" class="w-full text-xs bg-zinc-950 border border-zinc-800 rounded-lg p-2 text-zinc-300">
